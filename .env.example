# URL del SAP B1 backend (por defecto localhost:4100)
NEXT_PUBLIC_BACKEND_URL=http://localhost:4100

# URL completa del changelog service para este tenant/proyecto
CHANGELOG_URL=https://changelog-service-silk.vercel.app/api/changelog/<tenant>/<proyecto>

# GA ID del tenant (se pasa a initAnalytics() del DS)
# Obtener en Google Analytics → Admin → Data Streams
NEXT_PUBLIC_GA_ID=G-XXXXXXXXXX

# --- Changelog pill (read-path, público) ---
# Tenant/clientId del producto en el changelog-service (multitenant).
NEXT_PUBLIC_CHANGELOG_CLIENT=tamaprint
# appId (opcional; default interno = sap-b1-chat)
NEXT_PUBLIC_CHANGELOG_APP=sap-b1-chat
# URL del servicio (opcional; default = producción)
# NEXT_PUBLIC_CHANGELOG_URL=https://changelog-service-silk.vercel.app
